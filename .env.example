# 从 @BotFather 获取的 Bot Token（必填）
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxx

# 本地 LLM 的 OpenAI 兼容接口地址
# LM Studio 默认: http://localhost:1234/v1
# vLLM 默认:      http://localhost:8000/v1
LLM_BASE_URL=http://localhost:1234/v1

# 模型名称（LM Studio 可在服务器页面看到；vLLM 启动时 --model 指定的名称）
LLM_MODEL=local-model

# 本地服务一般不校验 key，随便填即可；vLLM 若设置了 --api-key 则填对应值
LLM_API_KEY=not-needed

# 可选：系统提示词（不填则使用内置默认值）
# SYSTEM_PROMPT=你是一个群聊助手...

# 可选：单次回答的最大 token 数
MAX_TOKENS=1024

# 可选：每条对话链保留的最大消息轮数
MAX_HISTORY=20

# 超级管理员的用户 ID（逗号分隔可填多个）。管理员永远可用 bot，
# 并可用 /adduser /deluser /listusers 随时管理白名单
# 注意：配置了管理员后即进入受控模式，只有管理员和白名单内的用户可用
ADMIN_USER_IDS=

# 可选：用户白名单初始值（逗号分隔的用户 ID）
# 仅首次启动时生效，之后以 allowed_users.json（/adduser /deluser 的结果）为准
# 管理员和白名单都留空 = 所有人可用
# ALLOWED_USER_IDS=123456789,987654321
