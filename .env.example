# Bot token from @BotFather / 从 @BotFather 获取的 Bot Token（必填）
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxx

# Bot message language: zh or en / bot 消息语言
BOT_LANG=zh

# OpenAI-compatible endpoint / OpenAI 兼容接口地址
# LM Studio: http://localhost:1234/v1   vLLM: http://localhost:8000/v1
# Official OpenAI: https://api.openai.com/v1
# Inside Docker, use http://host.docker.internal:port/v1 to reach the host
LLM_BASE_URL=http://localhost:1234/v1

# Model name / 模型名称（LM Studio 服务器页面或 vLLM --model 指定的名称）
LLM_MODEL=local-model

# Most local servers accept anything / 本地服务一般随便填；官方 API 填真实 key
LLM_API_KEY=not-needed

# Custom User-Agent for LLM requests (some cloud gateways validate it)
# 可选：自定义请求 UA（部分云端网关会校验），留空使用 SDK 默认值
# LLM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Optional system prompt / 可选：系统提示词（不填使用内置默认值）
# SYSTEM_PROMPT=You are a helpful group chat assistant...

# Max tokens per reply / 单次回答的最大 token 数
MAX_TOKENS=1024

# Messages kept per conversation / 每条对话链保留的最大消息条数
MAX_HISTORY=20

# Image understanding for vision-capable models / 图片理解（需模型支持视觉输入）
ENABLE_VISION=false

# Web search: lets the model search the internet via the web_search tool and
# read pages via the open_url tool
# (requires a model/backend with function calling support; auto-disabled otherwise).
# Providers / 搜索源:
#   tavily     - hosted, LLM-optimized, free tier ~1000/mo, needs API key from https://tavily.com
#   duckduckgo - no key needed (uses the `ddgs` package, already in requirements.txt)
#   searxng    - self-hosted SearXNG instance (JSON output format must be enabled)
# Multiple providers can be combined with commas — results are fetched
# concurrently, deduplicated and interleaved. e.g. SEARCH_PROVIDER=tavily,duckduckgo
# Empty = disabled (default) / 留空 = 关闭联网搜索
# 联网搜索：开启后模型可通过 web_search 搜索、open_url 读取网页（需模型支持 function calling）
# 可逗号分隔配置多个源，并发聚合、去重、交错合并结果
SEARCH_PROVIDER=
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx
# SEARXNG_BASE_URL=http://localhost:8080

# Search results fed back to the model per query / 单次搜索回灌给模型的结果条数
SEARCH_MAX_RESULTS=5

# Max page text characters fed back per open_url call / 单次读取网页回灌给模型的正文字数上限
# FETCH_CHAR_LIMIT=3500

# open_url fetches pages directly (trafilatura extraction). When a site blocks
# the bot (403), serves a JS-only shell, or yields too little text, it retries
# through Jina Reader (https://r.jina.ai) automatically. Set false to disable.
# open_url 直接抓取失败（反爬/JS 页面/正文过少）时自动改走 Jina Reader 兜底，false 关闭
# JINA_FALLBACK=true
# Optional Jina API key for higher rate limits / 可选：Jina key，速率限制更宽松
# JINA_API_KEY=jina_xxxxxxxxxxxxxxxx

# Super admin user IDs (comma-separated). Admins can always use the bot and
# manage the whitelist with /adduser /deluser /listusers.
# Setting this enables controlled mode: only admins + whitelisted users.
# 超级管理员 ID（逗号分隔）。配置后进入受控模式：仅管理员和白名单用户可用
ADMIN_USER_IDS=

# Initial whitelist (only used on first start, before allowed_users.json exists).
# Both empty = everyone can use the bot.
# 白名单初始值（仅首次启动生效，之后以 allowed_users.json 为准）；两者都留空 = 所有人可用
# ALLOWED_USER_IDS=123456789,987654321
