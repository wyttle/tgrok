# Bot token from @BotFather / 从 @BotFather 获取的 Bot Token（必填）
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxx

# Bot message language: zh or en / bot 消息语言
BOT_LANG=zh

# OpenAI-compatible endpoint / OpenAI 兼容接口地址
# LM Studio: http://localhost:1234/v1   vLLM: http://localhost:8000/v1
# Official OpenAI: https://api.openai.com/v1
# Inside Docker, use http://host.docker.internal:port/v1 to reach the host
LLM_BASE_URL=http://localhost:1234/v1

# Model name / 模型名称（LM Studio 服务器页面或 vLLM --model 指定的名称）
LLM_MODEL=local-model

# Most local servers accept anything / 本地服务一般随便填；官方 API 填真实 key
LLM_API_KEY=not-needed

# Custom User-Agent for LLM requests (some cloud gateways validate it)
# 可选：自定义请求 UA（部分云端网关会校验），留空使用 SDK 默认值
# LLM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Optional system prompt / 可选：系统提示词（不填使用内置默认值）
# SYSTEM_PROMPT=You are a helpful group chat assistant...

# Max tokens per reply / 单次回答的最大 token 数
MAX_TOKENS=1024

# Messages kept per conversation / 每条对话链保留的最大消息条数
MAX_HISTORY=20

# Image understanding for vision-capable models / 图片理解（需模型支持视觉输入）
ENABLE_VISION=false

# Super admin user IDs (comma-separated). Admins can always use the bot and
# manage the whitelist with /adduser /deluser /listusers.
# Setting this enables controlled mode: only admins + whitelisted users.
# 超级管理员 ID（逗号分隔）。配置后进入受控模式：仅管理员和白名单用户可用
ADMIN_USER_IDS=

# Initial whitelist (only used on first start, before allowed_users.json exists).
# Both empty = everyone can use the bot.
# 白名单初始值（仅首次启动生效，之后以 allowed_users.json 为准）；两者都留空 = 所有人可用
# ALLOWED_USER_IDS=123456789,987654321
